# ============================================================
#  Chatbot Crawler — Backend Environment Variables
#  Copy to .env and fill in your values.
# ============================================================

# ----------------------------------------------------------
#  Firecrawl  (required) — https://firecrawl.dev
# ----------------------------------------------------------
FIRECRAWL_API_KEY=

# ----------------------------------------------------------
#  Pinecone  (required) — https://pinecone.io
#  Create a serverless index with: dimensions=384, metric=cosine
# ----------------------------------------------------------
PINECONE_API_KEY=
PINECONE_INDEX_NAME=chatbot-crawler

# ----------------------------------------------------------
#  Supabase  (required) — https://supabase.com
#  Run the SQL in README.md to create the required tables.
# ----------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
# ----------------------------------------------------------
#  Groq  (required) — https://console.groq.com
# ----------------------------------------------------------
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ----------------------------------------------------------
#  Embedding model (optional — change only if you know what you're doing)
#  Must match the dimensions of your Pinecone index.
# ----------------------------------------------------------
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMS=384

# ----------------------------------------------------------
#  Chunking (optional)
# ----------------------------------------------------------
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
